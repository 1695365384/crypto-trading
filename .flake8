[flake8]
max-line-length = 100
max-complexity = 10
extend-ignore =
    E203,
    E501,
    W503,
    W504,
    C901
exclude =
    .git,
    __pycache__,
    .venv,
    venv,
    build,
    dist,
    *.egg-info
per-file-ignores =
    __init__.py: F401
    tests/*: F401 F811 E402
    scripts/*: E402
    envs/*: E402
